# Postgres connection string. In docker-compose this points at the `postgres`
# service; locally it points at a Postgres on your machine.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/caddiebook

# Secret used to sign our own access/refresh JWTs (HS256). Generate a long
# random value: `openssl rand -base64 48`.
JWT_SECRET=change-me-to-a-long-random-string

# Sign in with Apple: the app's bundle identifier is the token audience.
APPLE_BUNDLE_ID=com.caddiebook.app

# Google sign-in: comma-separated OAuth client IDs (iOS, Android, Web) that may
# appear as the id_token `aud`. Create these in Google Cloud Console.
GOOGLE_CLIENT_IDS=

# HTTP port the API listens on.
PORT=8080

# Set to 1 to enable POST /auth/dev (mints a token for a fixed dev user so sync
# can be exercised without real Apple/Google tokens). NEVER set in production.
DEV_AUTH=0
