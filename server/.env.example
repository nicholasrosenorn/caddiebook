# Postgres connection string. In docker-compose this points at the `postgres`
# service; locally it points at a Postgres on your machine.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/caddiebook

# Secret used to sign our own access/refresh JWTs (HS256). Generate a long
# random value: `openssl rand -base64 48`.
JWT_SECRET=change-me-to-a-long-random-string

# Sign in with Apple: the app's bundle identifier is the token audience.
APPLE_BUNDLE_ID=com.caddiebook.app

# Google sign-in: comma-separated OAuth client IDs (iOS, Android, Web) that may
# appear as the id_token `aud`. Create these in Google Cloud Console.
GOOGLE_CLIENT_IDS=

# HTTP port the API listens on.
PORT=8080

# Set to 1 to enable POST /auth/dev (mints a token for a fixed dev user so sync
# can be exercised without real Apple/Google tokens). NEVER set in production.
DEV_AUTH=0

# Cloudflare Tunnel token (production only — used by the cloudflared service in
# docker-compose.prod.yml). Create a tunnel in Cloudflare Zero Trust → Networks →
# Tunnels, add a Public Hostname routing to http://api:8080, and paste its token.
TUNNEL_TOKEN=

# --- Friend invite links ----------------------------------------------------
# Public origin invite links are served from. Defaults to the API host, which is
# correct as long as the universal-link domain matches the deployed hostname.
PUBLIC_BASE_URL=https://api.caddiebook.app

# iOS universal links: the app's "<AppleTeamID>.<bundleId>" (e.g.
# ABCDE12345.com.caddiebook.app). Written into the apple-app-site-association
# file. Find the Team ID in the Apple Developer portal / your EAS credentials.
APPLE_APP_ID=

# Android app links: the release signing certificate SHA-256 fingerprint
# (colon-separated hex). Get it from `eas credentials` or the Play Console
# (App integrity → App signing). Written into assetlinks.json.
ANDROID_SHA256_FINGERPRINT=

# Optional: numeric App Store id (e.g. 6444412345) — enables the iOS smart-app
# banner on the invite landing page. Leave empty to omit the banner.
APP_STORE_ID=

# Optional store links for the invite landing page (sensible defaults exist).
APP_STORE_URL=
PLAY_STORE_URL=
